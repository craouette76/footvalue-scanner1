<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>FootValue Scanner</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <style>
    body { font-family: system-ui, sans-serif; }
    .value-bar { animation: pulse 2s infinite; }
  </style>
</head>
<body class="bg-zinc-950 text-zinc-100 min-h-screen">
  <div class="max-w-4xl mx-auto p-4">
    <!-- Header -->
    <div class="flex items-center justify-between mb-8">
      <div class="flex items-center gap-3">
        <div class="w-12 h-12 bg-emerald-500 rounded-2xl flex items-center justify-center text-4xl">⚽</div>
        <h1 class="text-4xl font-bold tracking-tighter">FootValue Scanner</h1>
      </div>
      <div class="text-emerald-400 text-sm font-medium flex items-center gap-2">
        <div class="w-3 h-3 bg-emerald-400 rounded-full animate-pulse"></div>
        LIVE • Rafraîchi il y a 12s
      </div>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-3 gap-3 mb-8">
      <div class="bg-zinc-900 rounded-3xl p-4 text-center">
        <p class="text-zinc-400 text-sm">Value bets trouvées</p>
        <p class="text-4xl font-bold text-emerald-400">14</p>
      </div>
      <div class="bg-zinc-900 rounded-3xl p-4 text-center">
        <p class="text-zinc-400 text-sm">ROI simulé</p>
        <p class="text-4xl font-bold text-emerald-400">+18.7%</p>
      </div>
      <div class="bg-zinc-900 rounded-3xl p-4 text-center">
        <p class="text-zinc-400 text-sm">Alertes chaudes</p>
        <p class="text-4xl font-bold text-orange-400">3</p>
      </div>
    </div>

    <!-- Tableau Value Bets -->
    <h2 class="text-2xl font-semibold mb-4 flex items-center gap-2">
      🔥 Meilleures Value Bets
    </h2>
    <div class="bg-zinc-900 rounded-3xl overflow-hidden">
      <table class="w-full">
        <thead>
          <tr class="border-b border-zinc-800">
            <th class="text-left p-4 text-zinc-400">Match</th>
            <th class="text-left p-4 text-zinc-400">Marché</th>
            <th class="text-right p-4 text-zinc-400">Cote</th>
            <th class="text-right p-4 text-zinc-400">Value %</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-zinc-800">
          <tr class="hover:bg-zinc-800/50">
            <td class="p-4">Liverpool - Arsenal</td>
            <td class="p-4">Over 2.5 buts</td>
            <td class="p-4 text-right font-mono text-emerald-400">2.15</td>
            <td class="p-4 text-right"><span class="bg-emerald-500 text-white px-3 py-1 rounded-xl text-sm font-bold">+14%</span></td>
          </tr>
          <tr class="hover:bg-zinc-800/50">
            <td class="p-4">PSG - Monaco</td>
            <td class="p-4">1X2 (PSG gagne)</td>
            <td class="p-4 text-right font-mono text-emerald-400">1.68</td>
            <td class="p-4 text-right"><span class="bg-emerald-500 text-white px-3 py-1 rounded-xl text-sm font-bold">+11%</span></td>
          </tr>
          <tr class="hover:bg-zinc-800/50">
            <td class="p-4">Real Madrid - Betis</td>
            <td class="p-4">Both Teams To Score</td>
            <td class="p-4 text-right font-mono text-emerald-400">1.95</td>
            <td class="p-4 text-right"><span class="bg-emerald-500 text-white px-3 py-1 rounded-xl text-sm font-bold">+9%</span></td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- Alertes Chaudes -->
    <h2 class="text-2xl font-semibold mt-10 mb-4 text-orange-400 flex items-center gap-2">
      🔥 Alertes Chaudes
    </h2>
    <div class="bg-orange-500/10 border border-orange-500 rounded-3xl p-6">
      <p class="font-medium">Manchester City @ 1.58 → Probabilité estimée 78%</p>
      <p class="text-sm text-orange-300 mt-1">Cote anormalement haute sur un énorme favori</p>
      <button onclick="alert('Notification push envoyée !')" class="mt-4 w-full bg-orange-500 hover:bg-orange-600 py-3 rounded-2xl font-semibold">
        Activer notification push
      </button>
    </div>

    <div class="text-center text-zinc-500 text-xs mt-12">
      FootValue Scanner • Version démo mobile • Mise à jour automatique toutes les 45 secondes
    </div>
  </div>

  <script>
    // Tailwind script already loaded
    console.log('%cFootValue Scanner prêt ⚽', 'color:#10b981;font-size:13px;font-weight:bold');
  </script>
</body>
</html>
